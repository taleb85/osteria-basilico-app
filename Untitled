interface WeeklyShiftsTableProps {
  filterUserId?: string;
}

export default function WeeklyShiftsTable({ filterUserId }: WeeklyShiftsTableProps = {}) {
  const [weekOffset, setWeekOffset] = useState(0);
  const [selectedShiftIds, setSelectedShiftIds] = useState<string[]>([]);
  const anchorShiftIdRef = useRef<string | null>(null);
  const [dragSelect, setDragSelect] = useState<{ userIdx: number; dayIdx: number; slotIdx: number } | null>(null);
  const dragStartRef = useRef<{ userIdx: number; dayIdx: number; slotIdx: number } | null>(null);
  const dragSelectRef = useRef(dragSelect);
  dragSelectRef.current = dragSelect;
  const [creatingShift, setCreatingShift] = useState<{ userId: string; date: string; defaultTime: string } | null>(null);
  const [deletedShifts, setDeletedShifts] = useState<Shift[]>([]);
  const [showUndoNotification, setShowUndoNotification] = useState(false);
  const [showDeleteConfirm, setShowDeleteConfirm] = useState(false);
  const [isScrolled, setIsScrolled] = useState(false);
  const scrollContainerRef = useRef<HTMLDivElement>(null);
  const tableContainerRef = useRef<HTMLDivElement>(null);
  const { users, shifts, deleteShifts, updateShift, currentUser, punchRecords, publishWeekShifts, copyShift, addShift, showError, importWeek20260302, hasImported0208 } = useApp();
  const t = getTranslations(currentUser?.language);
  if (!currentUser) return null;

  const weekStart = startOfWeek(addWeeks(new Date(), weekOffset), { weekStartsOn: 1 });
  const allWeekDays = useMemo(() => Array.from({ length: 7 }, (_, i) => addDays(weekStart, i)), [weekStart]);

  const isManagement = currentUser.role === 'admin' || currentUser.role === 'manager' || currentUser.role === 'assistant_manager';
  const canApprove = currentUser.can_approve_shifts;
  const canCreateShifts = currentUser.can_create_shifts;
  const canEditShifts = isManagement;
  const canManageDrafts = currentUser.can_manage_drafts;
  const canViewTotalHours = currentUser.can_view_total_hours;
  const isStaff = currentUser.role === 'waiter' || currentUser.role === 'bartender';

  // Staff vede SOLO turni approvati o confermati (non bozze). Admin/Manager vedono tutto.
  // Admin, Manager, Assistente vedono anche dipendenti sospesi; Staff solo attivi.
  const canViewSuspended = isManagement;
  const visibleUserIds = useMemo(
    () => new Set(
      users
        .filter((u) => u.role !== 'admin' && (u.status === 'active' || (canViewSuspended && (u.status === 'suspended' || u.status === 'inactive'))))
        .map((u) => u.id)
    ),
    [users, canViewSuspended]
  );
  const visibleShifts = useMemo(() => {
    let list = shifts.filter(s => visibleUserIds.has(s.user_id));
    if (isStaff) list = list.filter(s => s.approval_status === 'approved' || s.approval_status === 'confirmed' || s.approval_status === 'standby');
    if (filterUserId) list = list.filter(s => s.user_id === filterUserId);
    return list;
  }, [shifts, visibleUserIds, isStaff, filterUserId]);

  const activeUsers = useMemo(() => {
    let list = users
      .filter((u) => u.role !== 'admin' && (u.status === 'active' || (canViewSuspended && (u.status === 'suspended' || u.status === 'inactive'))))
      .sort((a, b) => (a.sort_order ?? 0) - (b.sort_order ?? 0));
    if (filterUserId) list = list.filter((u) => u.id === filterUserId);
    return list;
  }, [users, canViewSuspended, filterUserId]);

  const shiftToPos = useMemo(() => {
    const m = new Map<string, { userIdx: number; dayIdx: number; slotIdx: number }>();
    activeUsers.forEach((u, ui) => {
      allWeekDays.forEach((day, di) => {
        const dayStr = format(day, 'yyyy-MM-dd');
        const dayShifts = visibleShifts.filter((s) => s.user_id === u.id && s.date === dayStr);
        const dayShift = dayShifts.find((s) => parseInt(s.start_time.split(':')[0], 10) < 16);
        const eveningShift = dayShifts.find((s) => parseInt(s.start_time.split(':')[0], 10) >= 16);
        if (dayShift) m.set(dayShift.id, { userIdx: ui, dayIdx: di, slotIdx: 0 });
        if (eveningShift) m.set(eveningShift.id, { userIdx: ui, dayIdx: di, slotIdx: 1 });
      });
    });
    return m;
  }, [activeUsers, allWeekDays, visibleShifts]);

  useEffect(() => {
    setSelectedShiftIds([]);
    anchorShiftIdRef.current = null;
  }, []);

  const validShiftIds = useMemo(() => new Set(shiftToPos.keys()), [shiftToPos]);
  useEffect(() => {
    setSelectedShiftIds((prev) => {
      const next = prev.filter((id) => validShiftIds.has(id));
      if (next.length === prev.length && next.every((id, i) => prev[i] === id)) return prev;
      return next;
    });
  }, [validShiftIds]);

  const getShiftsInRect = useCallback((r1: number, c1: number, s1: number, r2: number, c2: number, s2: number) => {
    const ids: string[] = [];
    const [ruMin, ruMax] = Math.min(r1, r2) <= Math.max(r1, r2) ? [Math.min(r1, r2), Math.max(r1, r2)] : [r1, r1];
    const [rdMin, rdMax] = Math.min(c1, c2) <= Math.max(c1, c2) ? [Math.min(c1, c2), Math.max(c1, c2)] : [c1, c1];
    const [rsMin, rsMax] = Math.min(s1, s2) <= Math.max(s1, s2) ? [Math.min(s1, s2), Math.max(s1, s2)] : [s1, s1];
    shiftToPos.forEach((pos, id) => {
      if (pos.userIdx >= ruMin && pos.userIdx <= ruMax && pos.dayIdx >= rdMin && pos.dayIdx <= rdMax && pos.slotIdx >= rsMin && pos.slotIdx <= rsMax) {
        ids.push(id);
      }
    });
    return ids;
  }, [shiftToPos]);

  const handleShiftClick = (shift: Shift, e: React.MouseEvent) => {
    if (isStaff) return;
    const shiftKey = e.shiftKey;
    const metaKey = e.metaKey || e.ctrlKey;
    if (shiftKey) {
      const anchor = anchorShiftIdRef.current;
      if (!anchor) {
        anchorShiftIdRef.current = shift.id;
        setSelectedShiftIds([shift.id]);
        return;
      }
      const p1 = shiftToPos.get(anchor);
      const p2 = shiftToPos.get(shift.id);
      if (!p1 || !p2) {
        setSelectedShiftIds([shift.id]);
        return;
      }
      const ids = getShiftsInRect(p1.userIdx, p1.dayIdx, p1.slotIdx, p2.userIdx, p2.dayIdx, p2.slotIdx);
      setSelectedShiftIds(ids);
    } else if (metaKey) {
      setSelectedShiftIds((prev) =>
        prev.includes(shift.id) ? prev.filter((id) => id !== shift.id) : [...prev, shift.id]
      );
    } else {
      anchorShiftIdRef.current = shift.id;
      setSelectedShiftIds((prev) =>
        prev.includes(shift.id) ? prev.filter((id) => id !== shift.id) : [shift.id]
      );
    }
  };

  const handleCellMouseDown = (_e: React.MouseEvent, _userIdx: number, _dayIdx: number, _slotIdx: number, _shift: Shift | null) => {
    /* Selezione solo tramite flag: nessun drag selection */
  };

  const handleCellMouseEnter = (userIdx: number, dayIdx: number, slotIdx: number) => {
    if (!dragStartRef.current) return;
    setDragSelect({ userIdx, dayIdx, slotIdx });
  };

  const handleCellMouseUp = useCallback(() => {
    dragStartRef.current = null;
    setDragSelect(null);
  }, []);

  useEffect(() => {
    window.addEventListener('mouseup', handleCellMouseUp);
    return () => window.removeEventListener('mouseup', handleCellMouseUp);
  }, [handleCellMouseUp]);

  useEffect(() => {
    const el = scrollContainerRef.current;
    if (!el) return;
    const onScroll = () => setIsScrolled(el.scrollLeft > 0);
    onScroll();
    el.addEventListener('scroll', onScroll);
    return () => el.removeEventListener('scroll', onScroll);
  }, []);

  useEffect(() => {
    const handleKeyDown = (e: KeyboardEvent) => {
      if (e.key === 'Escape') setSelectedShiftIds([]);
    };
    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, []);

  useEffect(() => {
    const handleClickOutside = (e: MouseEvent) => {
      if (tableContainerRef.current && !tableContainerRef.current.contains(e.target as Node)) {
        setSelectedShiftIds([]);
      }
    };
    document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, []);

  const daysMissingResponsible = useMemo(() => {
    const weekStr = format(weekStart, 'yyyy-MM-dd');
    const weekEnd = format(addDays(weekStart, 7), 'yyyy-MM-dd');
    const weekShifts = shifts.filter((s) => s.date >= weekStr && s.date < weekEnd);
    const responsibleRoles = ['manager', 'assistant_manager'];
    return allWeekDays.map((day) => {
      const dayStr = format(day, 'yyyy-MM-dd');
      const dayShifts = weekShifts.filter((s) => {
        const u = users.find((u) => u.id === s.user_id);
        return s.date === dayStr && u && u.status === 'active';
      });
      const hasResponsible = dayShifts.some((s) => {
        const u = users.find((u) => u.id === s.user_id);
        return u && responsibleRoles.includes(u.role);
      });
      return !hasResponsible && dayShifts.length > 0;
    });
  }, [shifts, users, weekStart, allWeekDays]);

  const needsCambioWarning = (shift: Shift) => {
    const endParts = (shift.end_time ?? '').split(':');
    const endHour = parseInt(endParts[0] ?? '0', 10);
    const endMin = parseInt(endParts[1] ?? '0', 10);
    if (endHour !== 16 || endMin !== 0) return false;
    const dayShifts = visibleShifts.filter((s) => s.date === shift.date && s.id !== shift.id);
    const hasCambio = dayShifts.some((s) => {
      const startHour = parseInt(s.start_time.split(':')[0], 10);
      return startHour <= 16;
    });
    return !hasCambio;
  };

  const getCellStyle = (shift: Shift, isSelected: boolean, hasAnySelected: boolean) => {
    if (shift.approval_status === 'standby') {
      let base = 'relative group flex flex-col items-center justify-center backdrop-blur-sm bg-blue-500/30 text-white border-2 border-blue-400/50';
      const selectedStyle = isSelected ? ' border-2 border-solid border-[#00A86B] ring-2 ring-[#00A86B]/30 ring-offset-1 ring-offset-[#2d572c]' : '';
      const dimmedStyle = hasAnySelected && !isSelected ? ' opacity-60' : '';
      return `${base} rounded-xl px-2 py-1.5 my-1 mx-0.5 cursor-pointer hover:opacity-90 transition-all duration-200${selectedStyle}${dimmedStyle}`;
    }
    const actual = getActualShiftTime(shift, punchRecords);
    const hasPunch = actual.isCompleted;
    const startNorm = (shift.start_time || '').slice(0, 5);
    const endNorm = (shift.end_time || '').trim().slice(0, 5);
    const hasEnd = !!endNorm && endNorm !== startNorm;
    let base = 'relative group flex flex-col items-center justify-center backdrop-blur-sm ';
    if (hasEnd) {
      base += 'bg-emerald-500/20 text-white border-2 border-emerald-500/50';
    } else if (hasPunch) {
      base += 'bg-yellow-500 text-white border-2 border-yellow-500/80';
    } else {
      base += 'bg-gray-600/25 text-white border-2 border-gray-500/40';
    }
    if (shift.approval_status === 'pending') {
      base += ' ring-2 ring-red-400/60 ring-inset';
    }
    const selectedStyle = isSelected
      ? ' border-2 border-solid border-[#00A86B] ring-2 ring-[#00A86B]/30 ring-offset-1 ring-offset-[#2d572c] shadow-[0_0_0_2px_rgba(0,168,107,0.25)]'
      : needsCambioWarning(shift)
        ? ' ring-2 ring-amber-400 ring-inset'
        : '';
    const dimmedStyle = hasAnySelected && !isSelected ? ' opacity-60' : '';
    return `${base} rounded-xl px-2 py-1.5 my-1 mx-0.5 cursor-pointer hover:opacity-90 transition-all duration-200${selectedStyle}${dimmedStyle}`;
  };


  const handleBulkCopy = () => {
    if (selectedShiftIds.length === 0) return;

    const shiftsToCopy = shifts.filter(s => selectedShiftIds.includes(s.id));
    const nextDay = prompt('Inserisci il numero di giorni da aggiungere (es: 1 per il giorno dopo, 7 per la settimana dopo):', '1');

    if (nextDay && !isNaN(parseInt(nextDay))) {
      shiftsToCopy.forEach(shift => {
        const newDate = format(addDays(parseISO(shift.date), parseInt(nextDay)), 'yyyy-MM-dd');
        copyShift(shift, newDate);
      });
      setSelectedShiftIds([]);
    }
  };

  const checkCambioViolation = useCallback(() => {
    const selShifts = shifts.filter((s) => selectedShiftIds.includes(s.id));
    for (const s of selShifts) {
      const endParts = (s.end_time ?? '').split(':');
      if (parseInt(endParts[0] ?? '0', 10) === 16 && parseInt(endParts[1] ?? '0', 10) === 0) {
        const dayShifts = shifts.filter((x) => x.date === s.date && x.user_id === s.user_id);
        const hasCambio = dayShifts.some((x) => parseInt(x.start_time.split(':')[0], 10) <= 16);
        if (!hasCambio) {
          showError('Manca il cambio delle 16:00 per questo giorno.');
          return true;
        }
      }
    }
    return false;
  }, [shifts, selectedShiftIds, showError]);

  const handleBulkApprove = () => {
    if (checkCambioViolation()) return;
    selectedShiftIds.forEach((id) => updateShift(id, { approval_status: 'approved' }));
    setSelectedShiftIds([]);
  };

  const handleUndoDelete = async () => {
    // Ripristina i turni eliminati reinserendoli
    for (const shift of deletedShifts) {
      const { id: _id, ...shiftData } = shift;
      await addShift(shiftData);
    }
    setDeletedShifts([]);
    setShowUndoNotification(false);
  };

  const GHOST_END = '23:00';

  /** Restituisce end_time effettivo: reale, 16:00 per 10:00, o 23:00 fantasma per draft serali senza fine. */
  const getEffectiveEnd = useCallback((shift: Shift): string | null => {
    const startNorm = (shift.start_time || '').trim().slice(0, 5);
    let endNorm = (shift.end_time || '').trim().slice(0, 5);
    if (startNorm === '10:00' && (!endNorm || endNorm === startNorm)) return '16:00';
    if (endNorm && endNorm !== startNorm) return endNorm;
    const startHour = parseInt(startNorm.split(':')[0], 10) || 0;
    if (shift.approval_status === 'draft' && startHour >= 16) return GHOST_END;
    return null;
  }, []);

  /** Ore confermate: solo turni confirmed con end_time reale (o 10:00->16:00). */
  const weeklyMinutesConfirmedByUser = useMemo(() => {
    const weekStr = format(weekStart, 'yyyy-MM-dd');
    const weekEnd = format(addDays(weekStart, 7), 'yyyy-MM-dd');
    const weekShifts = shifts.filter(
      (s) => s && s.date >= weekStr && s.date < weekEnd && s.approval_status === 'confirmed'
    );
    const byUser: Record<string, number> = {};
    for (const shift of weekShifts) {
      const end = getEffectiveEnd(shift);
      if (!end) continue;
      try {
        const startNorm = (shift.start_time || '').trim().slice(0, 5);
        const mins = calculateShiftMinutesSafe(startNorm, end);
        byUser[shift.user_id] = (byUser[shift.user_id] ?? 0) + mins;
      } catch {
        /* skip */
      }
    }
    return byUser;
  }, [shifts, weekStart, getEffectiveEnd]);

  /** Ore totali con stime fantasma: confermati + draft con 23:00 o 10:00->16:00. */
  const { weeklyMinutesTotalWithGhostByUser, hasGhostByUser } = useMemo(() => {
    const weekStr = format(weekStart, 'yyyy-MM-dd');
    const weekEnd = format(addDays(weekStart, 7), 'yyyy-MM-dd');
    const weekShifts = shifts.filter((s) => s && s.date >= weekStr && s.date < weekEnd);
    const byUser: Record<string, number> = {};
    const ghostByUser: Record<string, boolean> = {};
    for (const shift of weekShifts) {
      const end = getEffectiveEnd(shift);
      if (!end) continue;
      try {
        const startNorm = (shift.start_time || '').trim().slice(0, 5);
        const mins = calculateShiftMinutesSafe(startNorm, end);
        byUser[shift.user_id] = (byUser[shift.user_id] ?? 0) + mins;
        const isGhost = shift.approval_status === 'draft' && end === GHOST_END;
        if (isGhost) ghostByUser[shift.user_id] = true;
      } catch {
        /* skip */
      }
    }
    return { weeklyMinutesTotalWithGhostByUser: byUser, hasGhostByUser: ghostByUser };
  }, [shifts, weekStart, getEffectiveEnd]);

  const weekStr = format(weekStart, 'yyyy-MM-dd');
  const weekEnd = format(addDays(weekStart, 7), 'yyyy-MM-dd');

  const weekStats = useMemo(() => {
    const confirmed = Object.values(weeklyMinutesConfirmedByUser).reduce((a, b) => a + b, 0);
    const totalExpected = Object.values(weeklyMinutesTotalWithGhostByUser).reduce((a, b) => a + b, 0);
    return { confirmed, totalExpected, hasGhost: Object.keys(hasGhostByUser).some((k) => hasGhostByUser[k]) };
  }, [weeklyMinutesConfirmedByUser, weeklyMinutesTotalWithGhostByUser, hasGhostByUser]);

  const hasDraftShiftsInWeek = useMemo(() => {
    return shifts.some((s) => s.date >= weekStr && s.date < weekEnd && s.approval_status === 'draft');
  }, [shifts, weekStr, weekEnd]);

  const selectedShiftsData = useMemo(() => {
    return shifts.filter((s) => selectedShiftIds.includes(s.id));
  }, [shifts, selectedShiftIds]);

  const allSelectedApproved = selectedShiftsData.length > 0 && selectedShiftsData.every(
    (s) => s.approval_status === 'approved' || s.approval_status === 'confirmed'
  );

  const allSelectedPunched = selectedShiftsData.length > 0 && selectedShiftsData.every(
    (s) => getActualShiftTime(s, punchRecords).isCompleted
  );

  const selectedShiftCanClose = selectedShiftIds.length === 1 && (() => {
    const s = selectedShiftsData[0];
    if (!s) return false;
    const actual = getActualShiftTime(s, punchRecords);
    const startNorm = (s.start_time || '').slice(0, 5);
    const endNorm = (s.end_time || '').trim().slice(0, 5);
    const hasEnd = !!endNorm && endNorm !== startNorm;
    return actual.isCompleted && !hasEnd;
  })();

  const selectedShiftIsClosed = selectedShiftIds.length === 1 && (() => {
    const s = selectedShiftsData[0];
    if (!s) return false;
    const actual = getActualShiftTime(s, punchRecords);
    const startNorm = (s.start_time || '').slice(0, 5);
    const endNorm = (s.end_time || '').trim().slice(0, 5);
    const hasEnd = !!endNorm && endNorm !== startNorm;
    return actual.isCompleted && hasEnd;
  })();

  const selectedCell = selectedShiftIds.length > 0 && canEditShifts;

  const [showCloseShiftModal, setShowCloseShiftModal] = useState(false);
  const [showDayModal, setShowDayModal] = useState(false);
  const [showPublishWeekConfirm, setShowPublishWeekConfirm] = useState(false);
  const [isImporting0208, setIsImporting0208] = useState(false);
  const [editingEndTimeShiftId, setEditingEndTimeShiftId] = useState<string | null>(null);
  const [selectedDayForModal, setSelectedDayForModal] = useState<string | null>(null);
  const [isSavingModifications, setIsSavingModifications] = useState(false);
  const [editStartTime, setEditStartTime] = useState('');
  const [editEndTime, setEditEndTime] = useState('');
  // Edit mode: inline time editing + drag & drop
  const [isEditMode, setIsEditMode] = useState(false);
  const [draggedShiftId, setDraggedShiftId] = useState<string | null>(null);
  const [dropTargetKey, setDropTargetKey] = useState<string | null>(null); // "userId_date_slot"
  // Enhanced inline editor for both times in edit mode
  const [inlineEdit, setInlineEdit] = useState<{ shiftId: string; start: string; end: string } | null>(null);

  useEffect(() => {
    if (selectedShiftIds.length === 1 && selectedShiftsData[0]) {
      const s = selectedShiftsData[0];
      setEditStartTime((s.start_time || '').slice(0, 5));
      setEditEndTime((s.end_time || '').trim().slice(0, 5) || '');
    }
  }, [selectedShiftIds, selectedShiftsData]);

  const handleSaveModifications = useCallback(async () => {
    const shift = selectedShiftsData[0];
    if (!shift || isSavingModifications) return;
    const startNorm = toHHmm(editStartTime);
    const endNorm = toHHmm(editEndTime);
    if (!startNorm) return;
    setIsSavingModifications(true);
    try {
      await updateShift(shift.id, { start_time: startNorm, end_time: endNorm });
    } catch (err) {
      showError('Errore nel salvataggio. Riprova.');
    } finally {
      setIsSavingModifications(false);
    }
  }, [selectedShiftsData, editStartTime, editEndTime, isSavingModifications, updateShift, showError]);

  const handlePublishWeekClick = useCallback(() => {
    if (!hasDraftShiftsInWeek) return;
    setShowPublishWeekConfirm(true);
  }, [hasDraftShiftsInWeek]);

  const handlePublishWeekConfirm = useCallback(async () => {
    await publishWeekShifts(weekStart);
    setShowPublishWeekConfirm(false);
    setSelectedShiftIds([]);
  }, [publishWeekShifts, weekStart]);

  const handleCloseShiftClick = useCallback(() => {
    const shift = selectedShiftsData[0];
    if (!shift) return;

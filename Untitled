        disabled ? 'cursor-not-allowed opacity-60' : 'hover:opacity-90 transition-opacity'
      }`}
      style={{ fontFamily: '-apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif', fontWeight: 700 }}
    >
      {label}
    </button>
  );
}

const Separator = () => <div className="w-[1px] h-4 bg-white/20 mx-1.5 flex-shrink-0" />;


                                        <span className="text-[14px] font-bold text-blue-400" title="Reperibilità">?</span>
                                      </>
                                    );
                                  }
                                  const actualTimes = getActualShiftTime(eveningShift, punchRecords);
                                  const delayMin = getPunchDelayMinutes(eveningShift, punchRecords);
                                  const isDelayed = delayMin !== null && delayMin > 15;
                                  const isSelected = selectedShiftIds.includes(eveningShift.id) || isInDragRect(1);
                                  const startNormCell = (eveningShift.start_time || '').slice(0, 5);
                                  const endNormCell = (eveningShift.end_time || '').trim().slice(0, 5);
                                  const hasValidEnd = !!endNormCell && endNormCell !== startNormCell;
                                  const isInProgress = actualTimes.isCompleted && !hasValidEnd;
                                  const isClosed = actualTimes.isCompleted && hasValidEnd;
                                  const roleLabel = translateRole(user.role ?? '', (currentUser?.language ?? 'it') as 'it' | 'en' | 'es');
                                  const timeClass = 'text-xs font-semibold';
                                  const timeColor = isDelayed ? 'text-red-600 font-bold' : 'text-slate-50';
                                  const clockPulseClass = isInProgress ? 'animate-pulse-slow' : '';
                                  return (
                                    <>
                                      {isDelayed && (
                                        <span className="absolute top-0.5 left-0.5 w-1.5 h-1.5 rounded-full bg-red-500 z-10" title={`Ritardo ${delayMin} min`} />
                                      )}
                                      {actualTimes.isCompleted && (
                                        <span className={`absolute top-0.5 right-0.5 w-4 h-4 rounded-full bg-[#00A86B]/90 flex items-center justify-center flex-shrink-0 z-10 shadow-md border border-white/30 ${clockPulseClass}`} title={isClosed ? 'Chiuso' : 'Timbrato'} style={{ filter: 'drop-shadow(0 0 3px rgba(52,211,153,0.5))' }}>
                                          <Clock className="w-2.5 h-2.5 text-emerald-400" strokeWidth={2.5} />
                                        </span>
                                      )}
                                      {isSelected && !actualTimes.isCompleted && (
                                        <span className="absolute top-0.5 right-0.5 w-4 h-4 rounded-full bg-white flex items-center justify-center flex-shrink-0 z-10 shadow-md border border-white/20">
                                          <Check className="w-2.5 h-2.5 text-[#2d572c]" strokeWidth={3} />
                                        </span>
                                      )}
                                      <span className="text-[8px] font-bold font-sans uppercase tracking-wider text-white truncate w-full text-center" style={{ fontFamily: '-apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif' }}>
                                        {roleLabel}
                                      </span>
                                      {canEditShifts ? (
                                        <button
                                          type="button"
                                          draggable={isEditMode}
                                          onDragStart={(e) => { e.stopPropagation(); e.dataTransfer.setData('shiftId', eveningShift.id); setDraggedShiftId(eveningShift.id); }}
                                          onDragEnd={() => { setDraggedShiftId(null); setDropTargetKey(null); }}
                                          onClick={(e) => { e.stopPropagation(); if (!isEditMode) setEditingEndTimeShiftId(eveningShift.id); }}
                                          className={`font-sans tracking-wide ${timeClass} ${timeColor} cursor-pointer hover:underline underline-offset-1 ${isEditMode ? 'cursor-grab active:cursor-grabbing' : ''}`}
                                          style={{ fontFamily: '-apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif', opacity: draggedShiftId === eveningShift.id ? 0.4 : 1 }}
                                          title={isEditMode ? 'Trascina per spostare · Click per modificare' : t.insert_end_time}
                                        >
                                          {isEditMode ? '✏ ' : ''}{actualTimes.startTime.slice(0, 5)} – {actualTimes.endTime ? actualTimes.endTime.slice(0, 5) : '___'}
                                        </button>
                                      ) : (
                                        <span className={`font-sans tracking-wide ${timeClass} ${timeColor}`} style={{ fontFamily: '-apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif' }}>
                                          {actualTimes.startTime.slice(0, 5)} – {actualTimes.endTime ? actualTimes.endTime.slice(0, 5) : '___'}
                                        </span>
                                      )}
                                    </>
                                  );
                                })() : canManageThisUser && (
                                  <Plus className="w-4 h-4 text-white opacity-0 group-hover:opacity-100 transition-opacity" strokeWidth={2} />
                                )}
                              </div>
                            </div>
                          </td>
                        );
                      })}
                      <td className="px-4 py-4 text-center border-l-2 border-white/10 w-[80px] min-w-[80px] bg-black/15">
                        <div className="flex flex-col items-center justify-center" title={hasGhost ? t.ghost_tooltip : undefined}>
                          <span
                            className={`text-xs font-bold font-sans ${
                              confMins === 0 && prevMins === 0 ? 'text-gray-400' : 'text-white'
                            }`}
                            style={{ fontFamily: '-apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif' }}
                          >
                            {confMins === prevMins ? (
                              <>
                                {hasGhost && prevMins > 0 ? '*' : ''}
                                {formatMinutesToHoursAndMinutes(prevMins)}
                                {hasGhost && prevMins > 0 ? '*' : ''}
                              </>
                            ) : (
                              <>
                                <span className="text-emerald-400">{formatMinutesToHoursAndMinutes(confMins)}</span>
                                <span className="text-white/60 mx-0.5">/</span>
                                <span className={hasGhost ? 'text-sky-400/90 italic' : 'text-sky-400/90'}>
                                  {hasGhost && prevMins > 0 ? '*' : ''}
                                  {formatMinutesToHoursAndMinutes(prevMins)}
                                  {hasGhost && prevMins > 0 ? '*' : ''}
                                </span>
                              </>
                            )}
                          </span>
                        </div>
                      </td>
                    </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

      {/* Notifica Undo */}
      <AnimatePresence>
        {showUndoNotification && (
          <motion.div
            initial={{ x: 300, opacity: 0 }}
            animate={{ x: 0, opacity: 1 }}
            exit={{ x: 300, opacity: 0 }}
            transition={{ type: 'spring', damping: 25, stiffness: 300 }}
            className="fixed top-20 right-4 bg-black/15 backdrop-blur-xl text-white rounded-[20px] p-4 border-2 border-white/30 z-50 max-w-sm"
          >
            <div className="flex items-center justify-between space-x-4">
              <div>
                <p className="font-bold text-sm text-white font-sans">{t.shifts_deleted}</p>
                <p className="text-xs text-white/80 mt-1 font-sans">{t.undo_seconds}</p>
              </div>
              <motion.button
                whileHover={{ scale: 1.05 }}
                whileTap={{ scale: 0.95 }}
                onClick={handleUndoDelete}
                className="px-4 py-2 rounded-xl bg-[#00A86B] text-white font-bold hover:bg-[#00b877] transition-colors flex items-center space-x-2"
              >
                <Undo2 className="w-4 h-4" />
                <span>{t.undo}</span>
              </motion.button>
            </div>
          </motion.div>
        )}
      </AnimatePresence>

      <AnimatePresence>
        {showPublishWeekConfirm && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 bg-black/60 backdrop-blur-sm z-[200] flex items-center justify-center p-4"
            onClick={() => setShowPublishWeekConfirm(false)}
          >
            <motion.div
              initial={{ scale: 0.95, opacity: 0 }}
              animate={{ scale: 1, opacity: 1 }}
              exit={{ scale: 0.95, opacity: 0 }}
              onClick={(e) => e.stopPropagation()}
              className="bg-black/15 backdrop-blur-xl rounded-2xl w-full max-w-sm p-6 border-2 border-white/30 shadow-2xl font-sans"
            >
              <p className="text-white text-sm font-medium uppercase tracking-wider mb-6 text-center font-sans">
                {t.publish_week_confirm}
              </p>
              <div className="flex gap-3">
                <button
                  onClick={handlePublishWeekConfirm}
                  className="flex-1 py-3 rounded-xl bg-emerald-600 text-white text-xs font-medium uppercase tracking-wider hover:bg-emerald-500"
                >
                  {t.publish}
                </button>
                <button
                  onClick={() => setShowPublishWeekConfirm(false)}
                  className="flex-1 py-3 rounded-xl bg-black/15 text-white text-xs font-medium uppercase tracking-wider font-sans border-2 border-white/30"
                >
                  {t.cancel}
                </button>
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      <AnimatePresence>
        {showDeleteConfirm && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 bg-black/60 backdrop-blur-sm z-[200] flex items-center justify-center p-4"
            onClick={() => setShowDeleteConfirm(false)}
          >
            <motion.div
              initial={{ scale: 0.95, opacity: 0 }}
              animate={{ scale: 1, opacity: 1 }}
              exit={{ scale: 0.95, opacity: 0 }}
              onClick={(e) => e.stopPropagation()}
              className="bg-black/15 backdrop-blur-xl rounded-2xl w-full max-w-sm p-6 border-2 border-white/30 shadow-2xl font-sans"
            >
              <p className="text-white text-sm font-medium uppercase tracking-wider mb-6 text-center font-sans">
                {t.delete_shifts_confirm.replace('{n}', String(selectedShiftIds.length))}
              </p>
              <div className="flex gap-3">
                <button
                  onClick={async () => {
                    const shiftsToDelete = shifts.filter(s => selectedShiftIds.includes(s.id));
                    setDeletedShifts(shiftsToDelete);
                    await deleteShifts(selectedShiftIds);
                    setSelectedShiftIds([]);
                    setShowDeleteConfirm(false);
                    setShowUndoNotification(true);
                    setTimeout(() => setShowUndoNotification(false), 5000);
                  }}
                  className="flex-1 py-3 rounded-xl bg-red-500 text-white text-xs font-medium uppercase tracking-wider hover:bg-red-600"
                >
                  {t.delete_action}
                </button>
                <button
                  onClick={() => setShowDeleteConfirm(false)}
                  className="flex-1 py-3 rounded-xl bg-black/15 text-white text-xs font-medium uppercase tracking-wider font-sans border-2 border-white/30"
                >
                  {t.cancel}
                </button>
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      {creatingShift && (
        <CreateShiftModal
          userId={creatingShift.userId}
          date={creatingShift.date}
          defaultTime={creatingShift.defaultTime}
          onClose={() => setCreatingShift(null)}
        />
      )}

      <AnimatePresence>
      {editingEndTimeShiftId && (() => {
        const shift = shifts.find((s) => s.id === editingEndTimeShiftId);
        if (!shift) return null;
        const liveStart = inlineEdit?.shiftId === shift.id ? inlineEdit.start : (shift.start_time || '').slice(0, 5);
        const liveEnd = inlineEdit?.shiftId === shift.id ? inlineEdit.end : (shift.end_time || '').slice(0, 5);
        const liveBreaks = liveStart && liveEnd ? getBreakLabels(liveStart, liveEnd) : [];
        const liveNet = liveStart && liveEnd ? calculateShiftMinutesSafe(liveStart, liveEnd) : 0;

        return (
          <motion.div
            key="end-time-picker"
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 bg-black/60 backdrop-blur-sm z-[200] flex items-center justify-center p-4"
            onClick={() => { setEditingEndTimeShiftId(null); setInlineEdit(null); }}
          >
            <motion.div
              initial={{ scale: 0.95, opacity: 0 }}
              animate={{ scale: 1, opacity: 1 }}
              exit={{ scale: 0.95, opacity: 0 }}
              onClick={(e) => e.stopPropagation()}
              className="bg-[#1a2e1a]/95 backdrop-blur-xl rounded-2xl w-full max-w-xs p-5 border-2 border-emerald-700/50 shadow-2xl font-sans"
            >
              {isEditMode ? (
                /* ── Edit Mode: full start+end input editor ── */
                <>
                  <p className="text-amber-300 text-xs font-bold uppercase tracking-wider mb-4 text-center flex items-center justify-center gap-1.5">
                    <Pencil className="w-3.5 h-3.5" /> Modifica Orari
                  </p>
                  <div className="grid grid-cols-2 gap-3 mb-3">
                    <div className="flex flex-col gap-1">
                      <label className="text-[10px] font-bold text-white/50 uppercase tracking-wider">Inizio</label>
                      <input
                        type="time"
                        value={liveStart}
                        onChange={(e) => {
                          const v = e.target.value.slice(0, 5);
                          setInlineEdit((prev) => {
                            const base = prev ?? { shiftId: shift.id, start: liveStart, end: liveEnd };
                            const autoEnd = v === '10:00' && !base.end ? '16:00' : base.end;
                            return { ...base, start: v, end: autoEnd };
                          });
                        }}
                        autoFocus
                        className="h-10 px-3 rounded-xl bg-black/40 border border-white/30 text-white font-bold text-sm focus:outline-none focus:border-amber-400/60"
                      />
                    </div>
                    <div className="flex flex-col gap-1">
                      <label className="text-[10px] font-bold text-white/50 uppercase tracking-wider">Fine</label>
                      <input
                        type="time"
                        value={liveEnd}
                        onChange={(e) => {
                          const v = e.target.value.slice(0, 5);
                          setInlineEdit((prev) => ({ ...(prev ?? { shiftId: shift.id, start: liveStart, end: liveEnd }), end: v }));
                        }}
                        onKeyDown={(e) => { if (e.key === 'Enter') handleSaveInlineEdit(); }}
                        className="h-10 px-3 rounded-xl bg-black/40 border border-white/30 text-white font-bold text-sm focus:outline-none focus:border-amber-400/60"
                      />
                    </div>
                  </div>
                  {liveStart && liveEnd && (
                    <p className="text-center text-emerald-300 text-xs font-medium mb-3">
                      {formatMinutesToHoursAndMinutes(liveNet)}
                      {liveBreaks.length > 0 && <span className="ml-1 text-white/60">({liveBreaks.map((l) => (l === 'lunch' ? 'Pranzo' : 'Cena')).join(', ')})</span>}
                    </p>
                  )}
                  <div className="flex gap-2">
                    <button
                      type="button"
                      onClick={handleSaveInlineEdit}
                      className="flex-1 h-9 rounded-xl bg-emerald-600 text-white text-xs font-bold uppercase tracking-wider hover:bg-emerald-500 flex items-center justify-center gap-1.5 transition-colors"
                    >
                      <Save className="w-3.5 h-3.5" /> Salva
                    </button>
                    <button
                      type="button"
                      onClick={() => { setEditingEndTimeShiftId(null); setInlineEdit(null); }}
                      className="h-9 px-4 rounded-xl bg-black/30 text-white/70 text-xs font-semibold hover:bg-black/50 transition-colors"
                    >
                      {t.cancel}
                    </button>
                  </div>
                </>
              ) : (
                /* ── Normal mode: quick end-time grid ── */
                <>
                  <p className="text-white text-xs font-medium uppercase tracking-wider mb-3 text-center font-sans">
                    {t.insert_end_time}
                  </p>
                  <div className="grid grid-cols-3 gap-2 max-h-48 overflow-y-auto">
                    {END_TIME_OPTIONS.map((opt) => (
                      <button
                        key={opt}
                        type="button"
                        onClick={() => {
                          updateShift(shift.id, { end_time: opt });
                          setEditingEndTimeShiftId(null);
                        }}
                        className="py-2 px-2 rounded-lg bg-white/10 hover:bg-emerald-500/30 text-white text-xs font-medium border border-white/20"
                      >
                        {opt}
                      </button>
                    ))}
                  </div>
                  <button
                    type="button"
                    onClick={() => setEditingEndTimeShiftId(null)}
                    className="mt-3 w-full py-2 rounded-lg bg-black/15 text-white/80 text-xs font-medium border border-white/30"
                  >
                    {t.cancel}
                  </button>
                </>
              )}
            </motion.div>
          </motion.div>
        );
      })()}
      </AnimatePresence>

      {showCloseShiftModal && selectedShiftIds.length === 1 && selectedShiftsData[0] && (
        <CloseShiftModal
          shift={selectedShiftsData[0]}
          onClose={() => {
            setShowCloseShiftModal(false);
          }}
          onSaved={() => {
            setShowCloseShiftModal(false);
            setSelectedShiftIds([]);
          }}
        />
      )}

      {showDayModal && selectedDayForModal && (
        <DayShiftsModal
          dateStr={selectedDayForModal}
          onClose={() => {
            setShowDayModal(false);
            setSelectedDayForModal(null);
          }}
        />
      )}
    </div>
  );
}

interface DayShiftsModalProps {
  dateStr: string;
  onClose: () => void;
}

type ModalRowState = {
  user_id: string;
  date: string;
  start_time: string;
  end_time: string;
  approval_status: 'draft' | 'confirmed';
};

function DayShiftsModal({ dateStr, onClose }: DayShiftsModalProps) {
  const { users, shifts, punchRecords, updateShift, addShift, addPunchRecord, publishDayShifts, currentUser, showError } = useApp();
  const t = getTranslations(currentUser?.language ?? 'it');
  const [confirmingShiftId, setConfirmingShiftId] = useState<string | null>(null);
  const [publishing, setPublishing] = useState(false);
  const [savingAll, setSavingAll] = useState(false);
  const [localRows, setLocalRows] = useState<Map<string, ModalRowState>>(new Map());
  const canManageDrafts = currentUser?.can_manage_drafts ?? false;
  const canEdit = currentUser?.can_create_shifts ?? false;

  const orderedUsers = useMemo(
    () =>
      users
        .filter((u) => u.status === 'active')
        .sort((a, b) => {
          const pa = MODAL_STAFF_ORDER[a.first_name] ?? (a.sort_order ?? 99) + 100;
          const pb = MODAL_STAFF_ORDER[b.first_name] ?? (b.sort_order ?? 99) + 100;
          return pa - pb;
        }),
    [users]
  );

  const dayShiftsOrdered = useMemo(() => {
    const dayShifts = shifts.filter((s) => s.date === dateStr);
    const rows: Shift[] = [];
    for (const user of orderedUsers) {
      const userShifts = dayShifts.filter((s) => s.user_id === user.id).sort((a, b) => (a.start_time || '').localeCompare(b.start_time || ''));
      rows.push(...userShifts);
    }
    return rows;
  }, [shifts, dateStr, orderedUsers]);

  const hasDraftInDay = useMemo(() => dayShiftsOrdered.some((s) => s.approval_status === 'draft'), [dayShiftsOrdered]);

  // Initialise local rows once on mount
  useEffect(() => {
    const map = new Map<string, ModalRowState>();
    dayShiftsOrdered.forEach((s) => {
      map.set(s.id, {
        user_id: s.user_id,
        date: s.date,
        start_time: (s.start_time || '').trim().slice(0, 5),
        end_time: (s.end_time || '').trim().slice(0, 5),
        approval_status: s.approval_status === 'confirmed' ? 'confirmed' : 'draft',
      });
    });
    setLocalRows(map);
  // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []); // mount only — user types don't trigger this

  const updateLocalRow = (shiftId: string, patch: Partial<ModalRowState>) => {
    setLocalRows((prev) => {
      const map = new Map(prev);
      const row = map.get(shiftId);
      if (row) map.set(shiftId, { ...row, ...patch });
      return map;
    });
  };

  const rowHasChanges = (shift: Shift): boolean => {
    const row = localRows.get(shift.id);
    if (!row) return false;
    return (
      toHHmm(row.start_time) !== (shift.start_time || '').trim().slice(0, 5) ||
      toHHmm(row.end_time)   !== (shift.end_time   || '').trim().slice(0, 5) ||
      row.approval_status    !== (shift.approval_status === 'confirmed' ? 'confirmed' : 'draft') ||
      row.user_id            !== shift.user_id ||
      row.date               !== shift.date
    );
  };

  const hasAnyChanges = dayShiftsOrdered.some(rowHasChanges);

  const handleConfirmEntry = async (shift: Shift) => {
    setConfirmingShiftId(shift.id);
    try {
      await addPunchRecord(shift.user_id, 'in', { shift_id: shift.id });
    } catch (err) {
      showError('Errore durante la conferma entrata. Riprova.');
    } finally {
      setConfirmingShiftId(null);
    }
  };

  const handleSaveAll = async () => {
    setSavingAll(true);
    try {
      const changed = dayShiftsOrdered.filter(rowHasChanges);
      await Promise.all(changed.map((shift) => {
        const row = localRows.get(shift.id)!;
        return updateShift(shift.id, {
          user_id: row.user_id,
          date: row.date,
          start_time: toHHmm(row.start_time) || shift.start_time,
          end_time: toHHmm(row.end_time),
          approval_status: row.approval_status,
        });
      }));
      onClose();
    } catch (err) {
      showError('Errore nel salvataggio. Riprova.');
    } finally {
      setSavingAll(false);
    }
  };

  const handlePublishDay = async (e: React.MouseEvent) => {
    e.preventDefault();
    e.stopPropagation();
    setPublishing(true);
    try {
      if (hasAnyChanges) {
        const changed = dayShiftsOrdered.filter(rowHasChanges);
        await Promise.all(changed.map((shift) => {
          const row = localRows.get(shift.id)!;
          return updateShift(shift.id, {
            start_time: toHHmm(row.start_time) || shift.start_time,
            end_time: toHHmm(row.end_time),
            approval_status: row.approval_status,
          });
        }));
      }
      const auto16 = dayShiftsOrdered.filter(
        (s) => (s.start_time || '').slice(0, 5) === '10:00' && !(s.end_time || '').trim()
      );
      if (auto16.length > 0) {
        await Promise.all(auto16.map((s) => updateShift(s.id, { end_time: '16:00' })));
      }
      await publishDayShifts(dateStr);
      onClose();
    } catch (err) {
      showError('Errore durante la pubblicazione. Riprova.');
    } finally {
      setPublishing(false);
    }
  };

  return (
    <AnimatePresence>
      <motion.div
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        exit={{ opacity: 0 }}
        className="fixed inset-0 bg-black/70 backdrop-blur-md z-[200] flex items-center justify-center p-4"
        onClick={onClose}
      >
        <motion.div
          initial={{ scale: 0.9, opacity: 0 }}
          animate={{ scale: 1, opacity: 1 }}
          exit={{ scale: 0.9, opacity: 0 }}
          transition={{ type: 'spring', damping: 25, stiffness: 300 }}
          onClick={(e) => e.stopPropagation()}
          className="bg-[#1a2e1a]/95 backdrop-blur-xl rounded-[24px] w-full max-w-lg max-h-[85vh] border-2 border-emerald-900/50 shadow-[0_0_40px_rgba(0,168,107,0.15)] overflow-hidden font-sans flex flex-col"
        >
          <div className="border-b border-white/20 p-6 flex items-center justify-between flex-shrink-0">
            <div>
              <h2 className="text-white text-xl font-black uppercase tracking-wider font-sans">
                {t.day_shifts_management}
              </h2>
              <p className="text-white/80 text-sm mt-1 font-sans">
                {format(parseISO(dateStr), 'EEEE d MMM yyyy', { locale: getDateLocale(currentUser?.language) ?? it })}
              </p>
            </div>
            <button
              type="button"
              onClick={(e) => { e.preventDefault(); e.stopPropagation(); onClose(); }}
              className="w-10 h-10 rounded-full bg-black/30 hover:bg-black/25 flex items-center justify-center transition-colors border-2 border-white/30"
            >
              <X className="w-5 h-5 text-white" />
            </button>
          </div>

          <div className="p-4 overflow-y-auto flex-1 min-h-0">
            {dayShiftsOrdered.length === 0 ? (
              <p className="text-white/70 text-sm font-sans text-center py-8">{t.no_shifts_scheduled}</p>
            ) : (
              <div className="space-y-2">
                {dayShiftsOrdered.map((shift) => {
                  const user = users.find((u) => u.id === shift.user_id);
                  const row = localRows.get(shift.id) ?? {
                    user_id: shift.user_id, date: shift.date,
                    start_time: (shift.start_time || '').slice(0, 5),
                    end_time: (shift.end_time || '').slice(0, 5),
                    approval_status: shift.approval_status === 'confirmed' ? 'confirmed' as const : 'draft' as const,
                  };
                  const isDirty = rowHasChanges(shift);
                  const isConfirming = confirmingShiftId === shift.id;
                  const actual = getActualShiftTime(shift, punchRecords);
                  const canConfirmEntry = !actual.isCompleted;

                  // Live net hours from local row values
                  const lStart = toHHmm(row.start_time) || '';
                  const lEnd = toHHmm(row.end_time) || (lStart === '10:00' && !row.end_time ? '16:00' : '');
                  const lBreaks = lStart && lEnd ? getBreakLabels(lStart, lEnd) : [];
                  const lNet = lStart && lEnd ? calculateShiftMinutesSafe(lStart, lEnd) : 0;

                  return (
                    <div
                      key={shift.id}
                      className={`rounded-xl border transition-all duration-150 ${isDirty ? 'border-amber-500/50 bg-amber-500/5' : 'border-white/15 bg-[#1a2e1a]/60'}`}
                    >
                      <div className="flex flex-wrap items-center gap-2 p-3">
                        {/* Dirty indicator */}
                        {isDirty && <span className="w-2 h-2 rounded-full bg-amber-400 flex-shrink-0" title="Modifiche non salvate" />}

                        {/* Employee */}
                        {canEdit ? (
                          <div className="relative flex-shrink-0">
                            <select
                              value={row.user_id}
                              onChange={(e) => updateLocalRow(shift.id, { user_id: e.target.value })}
                              className="h-8 pl-2 pr-7 rounded-lg bg-black/30 border border-white/20 text-white text-xs font-bold appearance-none cursor-pointer min-w-[72px]"
                            >
                              {orderedUsers.map((u) => <option key={u.id} value={u.id}>{u.first_name}</option>)}
                            </select>
                            <ChevronDown className="absolute right-1.5 top-1/2 -translate-y-1/2 w-3 h-3 text-white/60 pointer-events-none" />
                          </div>
                        ) : (
                          <span className="font-bold text-white text-sm flex-shrink-0 min-w-[70px]">{user?.first_name ?? '-'}</span>
                        )}

                        {/* Times */}
                        {canEdit ? (
                          <div className="flex items-center gap-1.5 flex-shrink-0">
                            <input
                              type="time"
                              value={row.start_time}
                              onChange={(e) => {
                                const v = e.target.value.slice(0, 5);
                                updateLocalRow(shift.id, { start_time: v, end_time: v === '10:00' && !row.end_time ? '16:00' : row.end_time });
                              }}
                              className="h-8 w-[88px] px-2 rounded-lg bg-black/30 border border-white/20 text-white text-xs font-bold focus:outline-none focus:border-emerald-400/60"
                            />
                            <span className="text-white/40 text-xs">–</span>
                            <input
                              type="time"
                              value={row.end_time}
                              onChange={(e) => updateLocalRow(shift.id, { end_time: e.target.value.slice(0, 5) })}
                              className="h-8 w-[88px] px-2 rounded-lg bg-black/30 border border-white/20 text-white text-xs font-bold focus:outline-none focus:border-emerald-400/60"
                            />
                          </div>
                        ) : (
                          <span className="text-white text-sm font-semibold flex-shrink-0">
                            {(row.start_time || '--:--')} – {(row.end_time || '___')}
                          </span>
                        )}

                        {/* Status toggle */}
                        {canEdit ? (
                          <button
                            type="button"
                            onClick={(e) => { e.preventDefault(); e.stopPropagation(); updateLocalRow(shift.id, { approval_status: row.approval_status === 'draft' ? 'confirmed' : 'draft' }); }}
                            className={`h-6 px-2 rounded-md text-[9px] font-bold uppercase border flex-shrink-0 transition-colors ${
                              row.approval_status === 'confirmed'
                                ? 'bg-emerald-500/20 text-emerald-400 border-emerald-500/40'
                                : 'bg-gray-500/20 text-gray-400 border-gray-500/40'
                            }`}
                          >
                            {row.approval_status === 'confirmed' ? '✓ Conf.' : '○ Draft'}
                          </button>
                        ) : (
                          <span className={`h-6 px-2 rounded-md text-[9px] font-bold uppercase border flex-shrink-0 flex items-center ${row.approval_status === 'confirmed' ? 'bg-emerald-500/20 text-emerald-400 border-emerald-500/40' : 'bg-gray-500/20 text-gray-400 border-gray-500/40'}`}>
                            {row.approval_status === 'confirmed' ? '✓ Conf.' : '○ Draft'}
                          </span>
                        )}

                        {/* Live net hours */}
                        {lStart && lEnd && (
                          <span className="text-[10px] text-emerald-300/90 font-medium flex-shrink-0">
                            {formatMinutesToHoursAndMinutes(lNet)}
                            {lBreaks.length > 0 && (
                              <span className="ml-1 text-white/60">
                                ({lBreaks.map((l) => (l === 'lunch' ? t.break_lunch_applied : t.break_dinner_applied)).join(', ')})
                              </span>
                            )}
                          </span>
                        )}

                        {/* Confirm entry */}
                        {canConfirmEntry && (
                          <button
                            type="button"
                            onClick={(e) => { e.preventDefault(); e.stopPropagation(); handleConfirmEntry(shift); }}
                            disabled={isConfirming}
                            className="ml-auto h-7 px-2.5 rounded-lg bg-emerald-600/80 text-white text-[10px] font-semibold uppercase hover:bg-emerald-600 disabled:opacity-70 flex items-center gap-1 transition-colors flex-shrink-0"
                          >
                            {isConfirming ? <Loader2 className="w-3 h-3 animate-spin" /> : null}
                            {t.confirm_entry}
                          </button>
                        )}
                      </div>
                    </div>
                  );
                })}
              </div>
            )}
          </div>

          {/* Footer: Salva Tutto + Pubblica Giorno */}
          {(hasAnyChanges || (canManageDrafts && hasDraftInDay)) && (
            <div className="p-4 border-t border-white/20 flex gap-2 flex-shrink-0">
              {hasAnyChanges && (
                <button
                  type="button"
                  onClick={handleSaveAll}
                  disabled={savingAll || publishing}
                  className="flex-1 py-2.5 rounded-xl bg-amber-500 text-white font-bold text-sm uppercase tracking-wider hover:bg-amber-400 disabled:opacity-70 transition-colors flex items-center justify-center gap-2"
                >
                  {savingAll ? <Loader2 className="w-4 h-4 animate-spin" /> : <Save className="w-4 h-4" />}
                  Salva Tutto
                </button>
              )}
              {canManageDrafts && hasDraftInDay && (
                <button
                  type="button"
                  onClick={handlePublishDay}
                  disabled={publishing || savingAll}
                  className="flex-1 py-2.5 rounded-xl bg-emerald-600 text-white font-bold text-sm uppercase tracking-wider hover:bg-emerald-500 disabled:opacity-70 transition-colors flex items-center justify-center gap-2"
                >
                  {publishing ? <Loader2 className="w-4 h-4 animate-spin" /> : <Check className="w-4 h-4" />}
                  {t.publish_day}
                </button>
              )}
            </div>
          )}
        </motion.div>
      </motion.div>
    </AnimatePresence>
  );
}

interface CreateShiftModalProps {
  userId: string;
  date: string;
  defaultTime: string;
  onClose: () => void;
}

function CreateShiftModal({ userId, date, defaultTime, onClose }: CreateShiftModalProps) {
  const { users, addShift, currentUser } = useApp();
  const t = getTranslations(currentUser?.language ?? 'it');
  const [tempShifts, setTempShifts] = useState({
    start_time: (defaultTime || '').trim().slice(0, 5) || '10:00',
    end_time: '',
  });

  const user = users.find((u) => u.id === userId);

  const startHour = parseInt(tempShifts.start_time.split(':')[0], 10);
  /** Turni serali (>= 16:00): nessun end_time di default, chiusura manuale */
  const isOpenEndShift = startHour >= 16;
  const is10Shift = startHour === 10;

  useEffect(() => {
    if (is10Shift) setTempShifts((s) => ({ ...s, end_time: '16:00' }));
    else if (isOpenEndShift) setTempShifts((s) => ({ ...s, end_time: '' }));
  }, [tempShifts.start_time, is10Shift, isOpenEndShift]);

  const handleSave = async () => {
    const startNorm = toHHmm(tempShifts.start_time);
    if (!startNorm) return;
    const effectiveEnd = is10Shift ? '16:00' : (isOpenEndShift ? '' : toHHmm(tempShifts.end_time));
    if (!isOpenEndShift && !is10Shift && !effectiveEnd) return;
    const shiftType: 'lunch' | 'dinner' = startHour < 17 ? 'lunch' : 'dinner';
    const res = await addShift({
      user_id: userId,
      date,
      start_time: startNorm,
      end_time: effectiveEnd,
      type: shiftType,
      approval_status: 'draft',
    });
    if (res) onClose();
  };

  const inputClass = 'w-full px-4 py-3 rounded-2xl bg-black/15 border border-white/20 text-white placeholder:text-white/50 focus:border-white/40 focus:outline-none transition-colors font-sans font-bold';
  const labelClass = 'block text-sm font-bold text-white mb-2 font-sans';
  const btnClass = 'px-6 py-4 rounded-2xl font-bold text-white border border-white/20 hover:bg-black/25 transition-colors font-sans';

  return (
    <AnimatePresence>
      <motion.div
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        exit={{ opacity: 0 }}
        className="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4"
        onClick={onClose}
      >
        <motion.div
          initial={{ scale: 0.9, opacity: 0 }}
          animate={{ scale: 1, opacity: 1 }}
          exit={{ scale: 0.9, opacity: 0 }}
          transition={{ type: 'spring', damping: 25, stiffness: 300 }}
          onClick={(e) => e.stopPropagation()}
          className="bg-[#2d572c]/80 backdrop-blur-xl rounded-[32px] w-full max-w-md border-2 border-white/40 overflow-hidden font-sans"
        >
          <div className="border-b border-white/20 p-6 flex items-center justify-between">
            <div>
              <h2 className="text-white text-2xl font-black uppercase tracking-wider font-sans">
                {t.new_shift}
              </h2>
              <p className="text-white/80 text-sm mt-1 font-sans">
                <span className="uppercase">{user?.first_name}</span> • {format(parseISO(date), 'd MMM yyyy', { locale: getDateLocale(currentUser?.language) ?? it })}
              </p>
            </div>
            <button
              onClick={onClose}
              className="w-10 h-10 rounded-full bg-black/30 hover:bg-black/25 flex items-center justify-center transition-colors border-2 border-white/30"
            >
              <X className="w-5 h-5 text-white" />
            </button>
          </div>

          <div className="p-6 space-y-4">
            <div>
              <label className={labelClass}>
                {t.start_time}
              </label>
              <input
                type="time"
                value={tempShifts.start_time}
                onChange={(e) => setTempShifts((s) => ({ ...s, start_time: e.target.value }))}
                className={inputClass}
              />
            </div>

            {!isOpenEndShift && (
              <div>
                <label className={labelClass}>
                  {t.end_time}
                </label>
                <input
                  type="time"
                  value={tempShifts.end_time}
                  onChange={(e) => setTempShifts((s) => ({ ...s, end_time: e.target.value }))}
                  className={inputClass}
                />
              </div>
            )}
            {isOpenEndShift && (
              <div>
                <label className={labelClass}>
                  {t.end_time}
                </label>
                <p className="text-white/70 text-sm font-sans">
                  Chiusura manuale (Update Shift)
                </p>
              </div>
            )}

            <div className="flex space-x-3 pt-4">
              <button
                onClick={handleSave}
                className={`flex-1 ${btnClass} flex items-center justify-center space-x-2`}
              >
                <Save className="w-5 h-5 text-white" />
                <span>{t.create_shift}</span>
              </button>
              <button
                onClick={onClose}
                className={btnClass}
              >
                {t.cancel}
              </button>
            </div>
          </div>
        </motion.div>
      </motion.div>
    </AnimatePresence>
  );
}

interface CloseShiftModalProps {
  shift: Shift;
  onClose: () => void;
  onSaved: () => void;
}

function CloseShiftModal({ shift, onClose, onSaved }: CloseShiftModalProps) {
  const { users, updateShift, currentUser } = useApp();
  const t = getTranslations(currentUser?.language ?? 'it');
  const [endTime, setEndTime] = useState('');

  const user = users.find((u) => u.id === shift.user_id);

  const handleSave = () => {
    const effectiveEnd = (endTime === 'CURRENT' || !endTime || endTime.trim() === '') ? '23:00' : endTime.trim().slice(0, 5);
    if (!effectiveEnd) return;
    updateShift(shift.id, { end_time: effectiveEnd, approval_status: 'confirmed' });
    onSaved();
  };

  const labelClass = 'block text-sm font-bold text-white mb-2 font-sans';
  const btnClass = 'px-6 py-4 rounded-2xl font-bold text-white border border-white/20 hover:bg-black/25 transition-colors font-sans';

  return (
    <AnimatePresence>
      <motion.div
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        exit={{ opacity: 0 }}
        className="fixed inset-0 bg-black/60 backdrop-blur-sm z-[200] flex items-center justify-center p-4"
        onClick={onClose}
      >
        <motion.div
          initial={{ scale: 0.9, opacity: 0 }}
          animate={{ scale: 1, opacity: 1 }}
          exit={{ scale: 0.9, opacity: 0 }}
          transition={{ type: 'spring', damping: 25, stiffness: 300 }}
          onClick={(e) => e.stopPropagation()}
          className="bg-[#2d572c]/80 backdrop-blur-xl rounded-[32px] w-full max-w-md border-2 border-white/40 overflow-hidden font-sans"
        >
          <div className="border-b border-white/20 p-6 flex items-center justify-between">
            <div>
              <h2 className="text-white text-2xl font-black uppercase tracking-wider font-sans">
                {t.close_shift}
              </h2>
              <p className="text-white/80 text-sm mt-1 font-sans">
                <span className="uppercase">{user?.first_name}</span> • {format(parseISO(shift.date), 'd MMM yyyy', { locale: getDateLocale(currentUser?.language) ?? it })} • {shift.start_time.slice(0, 5)}
              </p>
            </div>
            <button
              onClick={onClose}
              className="w-10 h-10 rounded-full bg-black/30 hover:bg-black/25 flex items-center justify-center transition-colors border-2 border-white/30"
            >
              <X className="w-5 h-5 text-white" />
            </button>
          </div>

          <div className="p-6 space-y-4">
            <div>
              <label className={labelClass}>{t.end_time}</label>
              <div className="relative">
                <select
                  value={endTime}
                  onChange={(e) => setEndTime(e.target.value)}
                  className="w-full px-4 py-3 rounded-2xl bg-black/15 border border-white/20 text-white focus:border-white/40 focus:outline-none transition-colors font-sans font-bold appearance-none cursor-pointer pr-10"
                >
                  <option value="" className="bg-[#2d572c] text-white">{t.end_time}</option>
                  {END_TIME_OPTIONS.map((opt) => (
                    <option key={opt} value={opt} className="bg-[#2d572c] text-white">{opt}</option>
                  ))}
                </select>
                <ChevronDown className="absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-white/70 pointer-events-none" />
              </div>
            </div>

            <div className="flex space-x-3 pt-4">
              <button
                onClick={handleSave}
                disabled={!endTime}
                className={`flex-1 ${btnClass} flex items-center justify-center space-x-2 bg-emerald-600/80 hover:bg-emerald-600 disabled:opacity-50 disabled:cursor-not-allowed`}
              >
                <Save className="w-5 h-5 text-white" />
                <span>{t.save}</span>
              </button>
              <button onClick={onClose} className={btnClass}>
                {t.cancel}
              </button>
            </div>
          </div>
        </motion.div>
      </motion.div>
    </AnimatePresence>
  );
}

{
  "rewrites": [
    { "source": "/", "destination": "/app.html" },
    { "source": "/profilo", "destination": "/app.html" },
    { "source": "/(.*)", "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
        "headers": [
          { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' https://xzfcxjcwsyigdlsfmwwv.supabase.co wss://xzfcxjcwsyigdlsfmwwv.supabase.co https://*.vercel.app; font-src 'self' data:; frame-src 'self'; manifest-src 'self'; worker-src 'self' blob:" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(self), geolocation=(self), microphone=(), payment=()" },
          { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
        ]
    },
    {
      "source": "/app.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, s-maxage=0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/app-version.txt",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/Installa_FLOW.mobileconfig",
      "headers": [
        { "key": "Content-Type", "value": "application/x-apple.ashen-plist" },
        { "key": "Content-Disposition", "value": "inline" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, s-maxage=0" }
      ]
    }
  ]
}

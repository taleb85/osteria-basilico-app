# Supabase - Osteria Basilico
# Copia questo file in .env e inserisci i valori reali
#
# Produzione (Vercel): in Supabase → Authentication → URL Configuration imposta
# Site URL e Redirect URLs su https://osteria-basilico-app.vercel.app (o dominio custom).

# URL del progetto Supabase (es. https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Chiave anonima pubblica (sicura per il client). Alternativa al nuovo nome:
# VITE_SUPABASE_PUBLISHABLE_KEY=   (se impostata, ha priorità in src/lib/supabase.ts)
VITE_SUPABASE_ANON_KEY=

# Postgres per script npm (db:apply-shift-templates, db:ensure-users, …).
# Consigliato: SOLO pooler (evita EHOSTUNREACH su IPv6 con db.….supabase.co).
# Supabase → Settings → Database → Connection string → "Use connection pooling" ON (Session).
# DATABASE_POOLER_URL=postgresql://postgres.PROJECT_REF:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Opzionale (spesso IPv6 non raggiungibile da casa): direct
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres

# Chiave service role: SOLO per script Node in scripts/ (NON nel bundle Vite).
# CRITICAL: usa nome senza prefisso VITE_ per prevenire inclusione nel bundle client.
# In produzione Vercel: imposta come Environment Variable SOLO per Functions/Edge, MAI per Frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Titolo app visualizzato nell'interfaccia
VITE_APP_TITLE=Osteria Basilico

# Slug univoco del tenant (es. nome ristorante senza spazi)
VITE_TENANT_SLUG=

# PIN super admin per accesso funzioni avanzate
VITE_SUPER_ADMIN_PIN=

# Chiave service role esposta al client (solo se strettamente necessario)
VITE_SUPABASE_SERVICE_ROLE_KEY=

# Abilita download feature flags da Storage (true/false)
VITE_FEATURE_FLAGS_STORAGE_ENABLED=true

# Gemini API per Scan Photo turni (Vision)
VITE_GEMINI_API_KEY=

# Sviluppo: anteprima nel browser senza installare la PWA su:
#   - `npm run dev`
#   - `npm run preview` con URL localhost / 127.0.0.1
# Produzione (es. vercel.app): senza PWA installata il gate resta attivo salvo:
# VITE_ALLOW_BROWSER_APP=true
# (su Vercel: Environment Variables — da usare solo temporaneamente)

# Geofence timbrature (opzionale): attiva il flag in Impostazioni / Master Control.
# Priorità: coordinate salvate dall’Admin in Profili → geofence.json su Storage; altrimenti fallback:
# VITE_RESTAURANT_LAT=45.123456
# VITE_RESTAURANT_LNG=9.123456
# VITE_GEOFENCE_RADIUS_M=120

# Storage: bucket `app-config` (features.json, role_feature_templates.json, admin_sheet_modules.json, …).
# VITE_APP_CONFIG_STORAGE_ENABLED=false — disattiva parti del layer config che controllano quel flag.
# VITE_FEATURE_FLAGS_STORAGE_ENABLED=false — in dev disattiva il *download* da Storage per flags + template ruoli + moduli admin
# (salvataggio su Storage può restare attivo): utile solo se il bucket non esiste ancora. In produzione lasciar unset o true.
# VITE_APP_CONFIG_STORAGE_ENABLED=false

# Tabella Realtime `app_settings_sync_signal` (migrazione 20260322180000). Se non l’hai ancora creata su Supabase,
# imposta false per evitare GET 404 in console; dopo la migrazione rimuovi la riga o imposta true e cancella
# localStorage `osteria_app_settings_sync_signal_unavailable` (o `clearAppSettingsSyncSignalUnavailableFlag()` in console).
# VITE_APP_SETTINGS_SYNC_SIGNAL=false

# Sincronizzazione “config condivisa” (Storage app-config, client_sync_revision, segnale app_settings_sync_signal).
# false = niente pull/push automatici di quel layer; restano DB + Realtime su turni/utenti/timbrature/ferie.
# VITE_APP_CLOUD_SYNC=false

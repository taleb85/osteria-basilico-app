# ─── Configurazione Osteria Basilico ─────────────────────────────────────────
#
# Split in 2 file per sicurezza:
#   .env        → chiavi pubbliche (tracciato da git)
#   .env.local  → chiavi sensibili (NON tracciato — in .gitignore)
#
# Copia questo file in .env e .env.local, poi inserisci i valori reali.
#
# Origine canoniche in produzione (link copiabili, metadati). In locale non serve.
# VITE_PUBLIC_APP_ORIGIN=https://flow-workinmotion.pages.dev
#
# Produzione (Cloudflare Pages): in Supabase → Authentication → URL Configuration imposta
# Site URL e Redirect URLs sull'URL reale (es. https://flow-workinmotion.pages.dev o dominio custom).

# ═══ .env (pubbliche) ═══

# URL del progetto Supabase (es. https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Chiave anonima pubblica (sicura per il client). Alternativa al nuovo nome:
# VITE_SUPABASE_PUBLISHABLE_KEY=   (se impostata, ha priorità in src/lib/supabase.ts)
VITE_SUPABASE_ANON_KEY=

# Titolo app visualizzato nell'interfaccia
VITE_APP_TITLE=Osteria Basilico

# Slug univoco del tenant (es. nome ristorante senza spazi)
VITE_TENANT_SLUG=

# Abilita download feature flags da Storage (true/false)
VITE_FEATURE_FLAGS_STORAGE_ENABLED=true

# ═══ .env.local (sensibili — mai su git) ═══

# PIN super admin per accesso funzioni avanzate
VITE_SUPER_ADMIN_PIN=

# Chiave service role: SOLO per script Node in scripts/ (NON nel bundle Vite).
# CRITICAL: NON usare prefisso VITE_ per prevenire inclusione nel bundle client.
# In produzione: imposta su server/Edge se usi funzioni server-side, MAI VITE_ nel client.
VITE_SUPABASE_SERVICE_ROLE_KEY=

# Postgres per script npm (db:apply-shift-templates, db:ensure-users, …).
# Consigliato: SOLO pooler (evita EHOSTUNREACH su IPv6 con db.….supabase.co).
# Supabase → Settings → Database → Connection string → "Use connection pooling" ON (Session).
# DATABASE_POOLER_URL=postgresql://postgres.PROJECT_REF:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Opzionale (spesso IPv6 non raggiungibile da casa): direct
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres

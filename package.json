{
  "name": "osteria-basilico-app",
  "private": true,
  "version": "1.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite --config scripts/vite.config.mjs",
    "prebuild": "node scripts/generate-tenant-favicon.mjs || echo 'Skipping icon gen'",
    "build": "vite build --config scripts/vite.config.mjs",
    "lint": "eslint .",
    "preview": "vite preview --config scripts/vite.config.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name=flow-workinmotion --branch=main",
    "reset:production": "node scripts/reset-production.js",
    "clean:shifts": "node scripts/clean-shifts.js",
    "db:migrate-permissions": "node --dns-result-order=ipv4first scripts/run-migration-users-permissions.js",
    "db:reset-operational-perms": "node --dns-result-order=ipv4first scripts/run-reset-operational-permissions.js",
    "storage:push-default-role-templates": "node scripts/push-default-role-templates.js",
    "db:migrate-break-minutes": "node --dns-result-order=ipv4first scripts/run-migration-break-minutes.js",
    "db:migrate-punch-source": "node --dns-result-order=ipv4first scripts/run-migration-punch-source.js",
    "db:migrate-enabled-modules": "node --dns-result-order=ipv4first scripts/run-migration-enabled-modules.js",
    "db:ensure-users": "node --dns-result-order=ipv4first scripts/run-migration-users-all-columns.js",
    "db:check-ui-overrides": "node --dns-result-order=ipv4first scripts/db-check-ui-section-overrides.js",
    "db:delete-users-alex": "node --dns-result-order=ipv4first scripts/run-delete-users-named-alex.js",
    "db:merge-users-taleb": "node --dns-result-order=ipv4first scripts/run-merge-users-taleb.js",
    "db:delete-auth-users": "node scripts/delete-auth-users-by-id.js",
    "db:inspect-taleb-shifts": "node scripts/inspect-taleb-shifts.js",
    "db:apply-shift-templates": "node --dns-result-order=ipv4first scripts/run-shift-templates-schema.js",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs",
    "db:dedupe-shifts": "node scripts/dedupe-shifts-rest.mjs",
    "db:dedupe-shifts:execute": "node scripts/dedupe-shifts-rest.mjs --execute"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.57.4",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.35.1",
    "html5-qrcode": "^2.3.8",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.344.0",
    "pulltorefreshjs": "^0.1.22",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^9.8.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^25.0.1",
    "netlify-cli": "^25.6.0",
    "pg": "^8.20.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^2.1.8"
  }
}
